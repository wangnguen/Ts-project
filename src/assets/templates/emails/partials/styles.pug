style.
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }
  body {
    font-family: 'Roboto', -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif;
    background-color: #f9fafb;
    margin: 0;
    padding: 20px 0;
    font-size: 15px;
    line-height: 24px;
    color: #374151;
  }
  .container {
    max-width: 600px;
    margin: 0 auto;
    background-color: #ffffff;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid #e5e7eb;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }
  .header-banner {
    background: linear-gradient(135deg, #14b8a6 0%, #0d9488 100%);
    padding: 48px 32px;
    text-align: center;
    color: #ffffff;
    box-shadow: 0 2px 8px rgba(20, 184, 166, 0.2);
  }
  .header-banner h1 {
    font-size: 32px;
    font-weight: 800;
    margin: 0;
    letter-spacing: 0;
    line-height: 1.2;
    font-family: 'Roboto', -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif;
  }
  .content-wrapper {
    padding: 40px 32px;
  }
  .greeting {
    font-size: 16px;
    font-weight: 600;
    color: #111827;
    margin-bottom: 20px;
    padding-bottom: 16px;
    border-bottom: 2px solid #f0fdf4;
  }
  .greeting strong {
    font-weight: 700;
    color: #14b8a6;
  }
  .description {
    margin-bottom: 24px;
    color: #4b5563;
    font-size: 15px;
    line-height: 26px;
  }
  .description strong {
    color: #111827;
    font-weight: 700;
    margin: 0 4px;
  }
  .button-container {
    text-align: center;
    margin: 20px 0;
    padding: 24px;
    background-color: #f0fdf4;
    border-radius: 8px;
  }
  .button {
    display: inline-block;
    background: linear-gradient(135deg, #14b8a6 0%, #0d9488 100%);
    color: #ffffff;
    padding: 14px 52px;
    border-radius: 6px;
    text-decoration: none;
    font-weight: 600;
    font-size: 15px;
    box-shadow: 0 4px 12px rgba(20, 184, 166, 0.3);
    transition: all 0.2s;
  }
  .button:hover {
    opacity: 0.95;
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(20, 184, 166, 0.4);
  }
  .info-box {
    background: linear-gradient(135deg, #f0fdf4 0%, #ecfdf5 100%);
    border-left: 5px solid #10b981;
    padding: 18px 20px;
    border-radius: 6px;
    margin: 16px 0;
    box-shadow: 0 2px 8px rgba(16, 185, 129, 0.08);
  }
  .info-box p {
    margin: 0;
    color: #065f46;
    font-size: 14px;
    line-height: 24px;
    font-weight: 500;
  }
  .info-box strong {
    color: #047857;
    font-weight: 700;
  }
  .warning-box {
    background: linear-gradient(135deg, #fffbeb 0%, #fef3c7 100%);
    border-left: 5px solid #f59e0b;
    padding: 18px 20px;
    border-radius: 6px;
    margin: 16px 0;
    box-shadow: 0 2px 8px rgba(245, 158, 11, 0.08);
  }
  .warning-text {
    font-size: 14px;
    color: #92400e;
    margin: 0;
    line-height: 24px;
    font-weight: 500;
  }
  .warning-text strong {
    color: #78350f;
    font-weight: 700;
  }
  .code-box {
    background: linear-gradient(135deg, #f5f3ff 0%, #f3e8ff 100%);
    border-left: 5px solid #7c3aed;
    padding: 28px;
    border-radius: 8px;
    margin: 16px 0;
    text-align: center;
    box-shadow: 0 4px 12px rgba(124, 58, 237, 0.12);
  }
  .code-label {
    font-size: 11px;
    color: #6d28d9;
    font-weight: 800;
    margin-bottom: 16px;
    letter-spacing: 2px;
    text-transform: uppercase;
    font-family: 'Roboto', -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif;
  }
  .code-value {
    font-size: 42px;
    font-weight: 800;
    color: #7c3aed;
    letter-spacing: 4px;
    font-family: 'Roboto', -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif;
    margin: 0;
  }
  .divider {
    border: 0;
    border-top: 1px solid #e5e7eb;
    margin: 32px 0;
    height: 0;
  }
  .footer-section {
    background-color: #f8f9fa;
    padding: 28px 32px;
    border-top: 2px solid #e5e7eb;
    text-align: center;
    font-size: 13px;
    color: #6b7280;
  }
  .footer-text {
    margin: 8px 0;
    line-height: 20px;
  }
  .footer-link {
    color: #14b8a6;
    text-decoration: none;
    font-weight: 700;
    transition: color 0.2s;
  }
  .footer-link:hover {
    color: #0d9488;
    text-decoration: underline;
  }
  .icon-circle {
    width: 64px;
    height: 64px;
    margin: 0 auto 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #ecfdf5;
    border-radius: 50%;
  }
  .icon-circle img {
    width: 40px;
    height: 40px;
  }
